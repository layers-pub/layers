{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "layers_text": {
          "tokenizer": "icu_tokenizer",
          "filter": ["icu_normalizer", "icu_folding", "lowercase"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "uri": { "type": "keyword" },
      "did": { "type": "keyword" },
      "subject_uri": { "type": "keyword" },
      "subject_collection": { "type": "keyword" },
      "summary": {
        "type": "text",
        "analyzer": "layers_text"
      },
      "indexed_at": { "type": "date" }
    }
  }
}

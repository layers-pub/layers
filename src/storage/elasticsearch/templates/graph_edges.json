{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "layers_text": {
          "tokenizer": "icu_tokenizer",
          "filter": ["icu_normalizer", "icu_folding", "lowercase"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "uri": { "type": "keyword" },
      "did": { "type": "keyword" },
      "source_ref": { "type": "keyword" },
      "target_ref": { "type": "keyword" },
      "edge_type": { "type": "keyword" },
      "edge_set_ref": { "type": "keyword" },
      "confidence": { "type": "integer" },
      "indexed_at": { "type": "date" }
    }
  }
}

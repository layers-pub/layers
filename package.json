{
  "name": "@layers/appview",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Composable ATProto lexicons for representing, sharing, and interlinking linguistic annotation data in a decentralized network.",
  "scripts": {
    "validate": "node validate-lexicons.mjs",
    "dev": "./scripts/dev.sh local",
    "dev:tunnel": "./scripts/dev.sh tunnel",
    "dev:stop": "./scripts/dev.sh stop",
    "dev:db": "docker compose -f docker/docker-compose.yml up -d",
    "dev:db:stop": "docker compose -f docker/docker-compose.yml down",
    "dev:api": "tsx watch --env-file=.env.development src/index.ts",
    "dev:indexer": "tsx watch --env-file=.env.development src/indexer.ts",
    "dev:web": "cd web && pnpm dev",
    "dev:sidecar": "cd sidecar && uvicorn sidecar.main:app --reload --port 8000",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node validate-lexicons.mjs",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:compliance": "vitest run --config vitest.compliance.config.ts",
    "test:pre-deployment": "vitest run --config vitest.pre-deployment.config.ts",
    "db:migrate:up": "node-pg-migrate up",
    "db:migrate:down": "node-pg-migrate down",
    "db:migrate:create": "node-pg-migrate create"
  },
  "keywords": [
    "atproto",
    "lexicon",
    "linguistics",
    "annotation"
  ],
  "author": "Aaron Steven White",
  "license": "CC-BY-SA-4.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@atproto/api": "latest",
    "@atproto/identity": "latest",
    "@atproto/lexicon": "latest",
    "@atproto/oauth-client-node": "latest",
    "@atproto/xrpc-server": "latest",
    "@elastic/elasticsearch": "latest",
    "@hono/node-server": "latest",
    "@ipld/car": "latest",
    "@ipld/dag-cbor": "latest",
    "@opentelemetry/api": "latest",
    "@opentelemetry/auto-instrumentations-node": "latest",
    "@opentelemetry/exporter-metrics-otlp-http": "latest",
    "@opentelemetry/exporter-trace-otlp-http": "latest",
    "@opentelemetry/resources": "latest",
    "@opentelemetry/sdk-metrics": "latest",
    "@opentelemetry/sdk-node": "latest",
    "@opentelemetry/semantic-conventions": "latest",
    "bullmq": "latest",
    "cockatiel": "latest",
    "hono": "latest",
    "ioredis": "latest",
    "jose": "latest",
    "multiformats": "latest",
    "neo4j-driver": "latest",
    "node-pg-migrate": "latest",
    "pg": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "prom-client": "latest",
    "reflect-metadata": "latest",
    "tsyringe": "latest",
    "ws": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@atproto/syntax": "latest",
    "@eslint/js": "latest",
    "@testcontainers/elasticsearch": "^11.12.0",
    "@testcontainers/neo4j": "^11.12.0",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/node": "latest",
    "@types/pg": "latest",
    "@types/ws": "latest",
    "@vitest/coverage-v8": "latest",
    "concurrently": "^9.2.1",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-import": "latest",
    "prettier": "latest",
    "testcontainers": "^11.12.0",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}

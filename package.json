    "@atproto/xrpc-server": "latest",
    "@elastic/elasticsearch": "latest",
    "@hono/node-server": "latest",
    "@ipld/car": "latest",
    "@ipld/dag-cbor": "latest",
    "@opentelemetry/api": "latest",
    "@opentelemetry/auto-instrumentations-node": "latest",
    "@opentelemetry/exporter-metrics-otlp-http": "latest",
    "@opentelemetry/exporter-trace-otlp-http": "latest",
    "@opentelemetry/resources": "latest",
    "@opentelemetry/sdk-metrics": "latest",
    "@opentelemetry/sdk-node": "latest",
    "@opentelemetry/semantic-conventions": "latest",
    "@panproto/core": "file:/Users/awhite48/Projects/phrom/sdk/typescript",
    "bullmq": "latest",
    "cockatiel": "latest",
    "hono": "latest",
    "ioredis": "latest",
    "jose": "latest",
    "multiformats": "latest",

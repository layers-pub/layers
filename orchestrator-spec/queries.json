{
  "$schema": "dev.idiolect.spec.query",
  "description": "Declarative taxonomy of Layers appview read-only queries. Each entry maps 1:1 to a pub.layers.<namespace>.(get|list)* XRPC method declared in layers/lexicons/pub/layers and is transformed by idiolect-codegen into: a Rust query fn, an axum HTTP handler at `/xrpc/<nsid>`, a route registration, and a CLI subcommand. Hand-written predicates live in layers-orchestrator/src/predicates.rs; everything else is generated.",
  "conventions": {
    "http_path_template": "/xrpc/{nsid}",
    "http_query_mode": "xrpc",
    "auth": {
      "enforcement": "layers-auth",
      "service_auth_lxm": "{nsid}",
      "permission_set_for_reads": "pub.layers.authReadOnly"
    }
  },
  "queries": [
